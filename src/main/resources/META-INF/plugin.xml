<idea-plugin>
    <id>com.example.method-ref-finder</id>
    <name>Cross-Project Method Reference Finder</name>
    <version>2.1.6</version>
    <vendor email="dev@example.com">Example</vendor>

    <description><![CDATA[
        <p>在 Java 类/方法上右键，查找该方法（或类的所有方法）在所有已打开项目中的引用，导出 CSV（GBK 编码）。</p>
        <ul>
            <li><b>查找方法跨项目引用</b>：在方法上右键，导出该方法的所有引用到 CSV。</li>
            <li><b>查找类所有方法跨项目引用</b>：在类上右键，批量导出类中所有方法的引用到 CSV。</li>
        </ul>
        <p>CSV 列：源方法、目标项目、引用方法，格式如
        <code>com.example.Foo#bar(java.lang.String)</code>。</p>
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.java</depends>

    <actions>
        <action id="com.example.plugin.FindMethodReferences"
                class="com.example.plugin.action.FindMethodReferencesAction"
                text="查找方法跨项目引用 (导出CSV)"
                description="查找该方法在所有已打开项目中的调用引用，结果导出为 GBK 编码 CSV">
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
        </action>

        <action id="com.example.plugin.FindClassMethodReferences"
                class="com.example.plugin.action.FindClassMethodReferencesAction"
                text="查找类所有方法跨项目引用 (导出CSV)"
                description="查找该类全部方法在所有已打开项目中的调用引用，结果导出为 GBK 编码 CSV">
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
        </action>

        <action id="com.example.plugin.FindMethodReferencesPreview"
                class="com.example.plugin.action.FindMethodReferencesPreviewAction"
                text="查找方法跨项目引用 (预览CSV)"
                description="查找该方法在所有已打开项目中的调用引用，结果在 Tool Window 只读编辑器中预览">
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
        </action>

        <action id="com.example.plugin.FindClassMethodReferencesPreview"
                class="com.example.plugin.action.FindClassMethodReferencesPreviewAction"
                text="查找类所有方法跨项目引用 (预览CSV)"
                description="查找该类全部方法在所有已打开项目中的调用引用，结果在 Tool Window 只读编辑器中预览">
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
        </action>
        <action id="com.example.plugin.FindPackageReferences"
                class="com.example.plugin.action.FindPackageReferencesAction"
                text="查找包内引用 (导出CSV)"
                description="查找包（含子包）内所有类及其方法在所有已打开项目中被引用的位置，结果导出为 GBK 编码 CSV">
            <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
        </action>

        <action id="com.example.plugin.FindPackageReferencesPreview"
                class="com.example.plugin.action.FindPackageReferencesPreviewAction"
                text="查找包内引用 (预览CSV)"
                description="查找包（含子包）内所有类及其方法在所有已打开项目中被引用的位置，结果在 Tool Window 表格中预览">
            <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
        </action>

        <action id="com.example.plugin.AnalyzeMethodChainPreview"
                class="com.example.plugin.action.AnalyzeMethodChainPreviewAction"
                text="分析方法引用链 (预览CSV)"
                description="查找该方法的跨项目引用，并对每条引用方法再往上追溯 4 层，标注引用链是否终止，结果在 Tool Window 中预览">
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
        </action>

        <action id="com.example.plugin.AnalyzeClassChainPreview"
                class="com.example.plugin.action.AnalyzeClassChainPreviewAction"
                text="分析类方法引用链 (预览CSV)"
                description="查找该类全部方法的跨项目引用，并对每条引用方法再往上追溯 4 层，标注引用链是否终止，结果在 Tool Window 中预览">
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
        </action>

        <action id="com.example.plugin.FindPackageWithCachePreview"
                class="com.example.plugin.action.FindPackageWithCachePreviewAction"
                text="查找包内引用(含Cache检查)(预览CSV)"
                description="查找包内所有类及方法的引用，并检查每条引用位置是否调用了含 cache 关键词的方法，结果在 Tool Window 中预览">
            <add-to-group group-id="ProjectViewPopupMenu" anchor="after"
                          relative-to-action="com.example.plugin.FindPackageReferencesPreview"/>
        </action>

        <action id="com.example.plugin.FindPackageWithControllerPreview"
                class="com.example.plugin.action.FindPackageWithControllerPreviewAction"
                text="查找包内引用(含Controller接口检查)(预览CSV)"
                description="查找包内所有类及方法的引用，并检查每条引用位置是否为 RestController/Controller 接口方法，若是则输出完整 HTTP 接口路径，结果在 Tool Window 中预览">
            <add-to-group group-id="ProjectViewPopupMenu" anchor="after"
                          relative-to-action="com.example.plugin.FindPackageWithCachePreview"/>
        </action>

        <action id="com.example.plugin.FindPackageWithUsageCheckPreview"
                class="com.example.plugin.action.FindPackageWithUsageCheckPreviewAction"
                text="查找包内引用(含被引用检查)(预览CSV)"
                description="查找包内所有类及方法的引用，并检查每条引用位置的方法/类自身在目标项目中是否有调用方（是/否），结果在 Tool Window 中预览">
            <add-to-group group-id="ProjectViewPopupMenu" anchor="after"
                          relative-to-action="com.example.plugin.FindPackageWithControllerPreview"/>
        </action>

        <action id="com.example.plugin.FindPackageMethodsWithCallerCheckPreview"
                class="com.example.plugin.action.FindPackageMethodsWithCallerCheckPreviewAction"
                text="查找包内方法引用(含被引用检查)(预览CSV)"
                description="查找包内所有类的方法引用（仅方法级别），并检查每条引用位置的调用方方法自身是否被其他代码引用（是/否），结果在 Tool Window 中预览">
            <add-to-group group-id="ProjectViewPopupMenu" anchor="after"
                          relative-to-action="com.example.plugin.FindPackageWithUsageCheckPreview"/>
        </action>

        <action id="com.example.plugin.FindPackageClassRefsWithImportCheckPreview"
                class="com.example.plugin.action.FindPackageClassRefsWithImportCheckPreviewAction"
                text="查找包内类引用(含import清理检查)(预览CSV)"
                description="查找包内所有类被引用的位置（仅类级别），并检查每条引用处的 import 是否可以清理（是/否），结果在 Tool Window 中预览">
            <add-to-group group-id="ProjectViewPopupMenu" anchor="after"
                          relative-to-action="com.example.plugin.FindPackageMethodsWithCallerCheckPreview"/>
        </action>

        <action id="com.example.plugin.AnalyzePackageChainPreview"
                class="com.example.plugin.action.AnalyzePackageChainPreviewAction"
                text="分析包内引用链 (预览CSV)"
                description="查找包（含子包）内所有类及其方法的跨项目引用，并对每条引用方法再往上追溯 4 层，标注引用链是否终止，结果在 Tool Window 中预览">
            <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
        </action>

        <action id="com.example.plugin.AnalyzeMethodCommentsPreview"
                class="com.example.plugin.action.AnalyzeMethodCommentsPreviewAction"
                text="查看方法引用链注释 (预览CSV)"
                description="查找该方法的跨项目引用，收集每条引用方法及其向上 4 层调用链的 Javadoc 注释（无注释时回退到接口/父类），拼接后在 Tool Window 中预览">
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
        </action>

        <action id="com.example.plugin.AnalyzeClassCommentsPreview"
                class="com.example.plugin.action.AnalyzeClassCommentsPreviewAction"
                text="查看类方法引用链注释 (预览CSV)"
                description="查找该类全部方法的跨项目引用，收集每条引用方法及其向上 4 层调用链的 Javadoc 注释（无注释时回退到接口/父类），拼接后在 Tool Window 中预览">
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
        </action>

        <action id="com.example.plugin.AnalyzePackageCommentsPreview"
                class="com.example.plugin.action.AnalyzePackageCommentsPreviewAction"
                text="查看包内引用链注释 (预览CSV)"
                description="查找包（含子包）内所有类及其方法的跨项目引用，收集每条引用方法及其向上 4 层调用链的 Javadoc 注释（无注释时回退到接口/父类），拼接后在 Tool Window 中预览">
            <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
        </action>

        <action id="com.example.plugin.InputMethodRefsWithCommentsPreview"
                class="com.example.plugin.action.InputMethodRefsWithCommentsPreviewAction"
                text="输入方法签名查引用注释 (预览CSV)"
                description="输入多行方法签名，批量查找跨项目引用，输出源方法注释（含接口/父类来源）和引用链注释（最多 3 层，每层含接口/父类来源），结果在 Tool Window 中预览">
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
        </action>

        <action id="com.example.plugin.TraceEndpointChainPreview"
                class="com.example.plugin.action.TraceEndpointChainPreviewAction"
                text="追溯入口链路 (预览CSV)"
                description="输入方法签名，向上追溯调用链至 RestController/KafkaListener/Scheduled 入口，支持跨微服务追踪（通过 restService.properties + exchangeInApp），结果在 Tool Window 中预览">
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
